/*
	Menu with secret gloves colors
*/

Class MRIntWeaps_EasterMenu: OptionMenu
{
	int Mus;
	Override Void Init(Menu parent, OptionMenuDescriptor desc){
		super.Init(parent, desc);
		Mus = 0;
		Sprite = Texman.CheckForTexture("PUNGD0");
		Alpha = 1.2;
	}
	
