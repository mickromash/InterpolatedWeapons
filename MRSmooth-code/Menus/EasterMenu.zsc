		Mus++;
		
		Screen.DrawTexture(Sprite, false, Pos.X, Pos.Y,
				DTA_DestWidthF, Scale.X,
				DTA_DestHeightF, Scale.Y,
				DTA_FlipX, Flip,
				DTA_Alpha, Alpha
		);
