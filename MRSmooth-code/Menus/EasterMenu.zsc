	Const EpilepsyIndex = 5;
	//Show epilepsy message if gloves color is set to "Fast Rainbow" or "Epilepsy"
	Override Bool MenuEvent(int mkey, bool fromcontroller)
	{
		Bool Ret = Super.MenuEvent(mkey, fromcontroller);
		
		int Var1 = CVar.FindCVar("MRIntW_GlovesColor").GetInt();
		
		if(Var1>9 && Var1<12){
			if(!OptionMenuItemStaticText(mDesc.mItems[EpilepsyIndex+1])){
				For(int i=0;i<4;i++){
					Let a = New('OptionMenuItemStaticText');
					a.mLabel = "$MRIntW_EpilepsyDesc"..(i+1);
					a.mCentered = true;
					a.mColor = Color(255,255,0);
					mDesc.mItems.Insert(EpilepsyIndex+i, a);
				}
			}
		}
		
		else {
			if(OptionMenuItemStaticText(mDesc.mItems[EpilepsyIndex+1])){
				mDesc.mItems.Delete(EpilepsyIndex, 4);
			}
		}
		Return Ret;
	}
}