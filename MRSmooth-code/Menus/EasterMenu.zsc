			Case 48+69:
				Sprite = Texman.CheckForTexture("TROOH1");
				Scale = Texman.GetScaledSize(Sprite);
				Pos = (Screen.GetWidth()*.5 - Scale.X*CleanXFac, Screen.GetHeight()+Scale.Y*CleanXFac*5);
				Scale *= CleanXFac*10;
				Flip = false;
				
				S_StartSound("grunt/pain", 1, CHANF_UI, 1, ATTN_NORM, 1);
