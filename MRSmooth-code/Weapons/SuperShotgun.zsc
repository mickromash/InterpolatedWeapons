					A_OverlayRotate(Lay1, .2, WOF_ADD);
				}
				else {
					A_OverlayOffset(Lay1, -6, -6, WOF_ADD);
					A_OverlayRotate(Lay1, 1, WOF_ADD);
				}
				
				if(invoker.SwitchState>0){
					invoker.SwitchState--;
					A_SetTics(0);
					if(Player.FindPSprite(LHand)){
						Player.GetPSprite(LHand).Tics = 0;
						Player.SetPsprite(LHand, Player.GetPSprite(LHand).CurState.NextState);
					}
				}
			}
			#### # 1 {
				if(invoker.SwitchAnim){
					A_OverlayOffset(Lay1, 5, 11, WOF_ADD);
					A_OverlayRotate(Lay1, 4, WOF_ADD);
				}
				else {
					A_OverlayOffset(Lay1, -3, -3, WOF_ADD);
					A_OverlayRotate(Lay1, .5, WOF_ADD);
				}
				
				if(invoker.SwitchState>0){
					invoker.SwitchState--;
					A_SetTics(0);
					if(Player.FindPSprite(LHand)){
						Player.GetPSprite(LHand).Tics = 0;
						Player.SetPsprite(LHand, Player.GetPSprite(LHand).CurState.NextState);
					}
				}
			}
			#### ## 1 {
				if(invoker.SwitchAnim){
					A_OverlayOffset(Lay1, 5, 11, WOF_ADD);
					A_OverlayRotate(Lay1, 4, WOF_ADD);
				}
				else {
					A_OverlayOffset(Lay1, 10, 14, WOF_ADD);
					A_OverlayRotate(Lay1, -1, WOF_ADD);
				}
				
				if(invoker.SwitchState>0){
					invoker.SwitchState--;
					A_SetTics(0);
					if(Player.FindPSprite(LHand)){
						Player.GetPSprite(LHand).Tics = 0;
						Player.SetPsprite(LHand, Player.GetPSprite(LHand).CurState.NextState);
					}
				}
			}
			#### # 1 {
				if(invoker.SwitchAnim){
					A_OverlayOffset(Lay1, 5, 11, WOF_ADD);
					A_OverlayRotate(Lay1, 4, WOF_ADD);
				}
				else {
					A_OverlayOffset(Lay1, 7, 10, WOF_ADD);
					A_OverlayRotate(Lay1, -1, WOF_ADD);
					A_OverlayScale(Lay1, .025, .025, WOF_ADD);
				}
				
				if(invoker.SwitchState>0){
					invoker.SwitchState--;
					A_SetTics(0);
					if(Player.FindPSprite(LHand)){
						Player.GetPSprite(LHand).Tics = 0;
						Player.SetPsprite(LHand, Player.GetPSprite(LHand).CurState.NextState);
					}
				}
			}
			Wait;
		LeftHandRaise:
			MRD1 G 1 {
				A_GlovesColor();
				A_OverlayFlags(LHand, PSPF_MIRROR, true);
				A_OverlayFlags(LHand, PSPF_ADDWEAPON, false);
				A_OverlayPivot(LHand, 1, 0);
				A_OverlayOffset(LHand, 160, 130);
				A_OverlayRotate(LHand, -20);
