			}
			#### GGGGGGGGG 1{
				A_OverlayOffset(LHand, -2, -5, WOF_ADD);
				A_OverlayRotate(LHand, -2, WOF_ADD);
				A_OverlayScale(LHand, -.04, -.04, WOF_ADD);
			}
			#### G 1{
				A_OverlayOffset(LHand, -3, 2, WOF_ADD);
				A_OverlayScale(LHand, .005, .005, WOF_ADD);
			}
			Stop;
		LeftHandLower:
			MRD1 G 1 {
				A_GlovesColor();
				A_OverlayFlags(LHand, PSPF_MIRROR, true);
				A_OverlayFlags(LHand, PSPF_ADDWEAPON, false);
				A_OverlayPivot(LHand, 1, 0);
				A_OverlayOffset(LHand, 133, 30+32);
				A_OverlayRotate(LHand, -23);
				A_OverlayScale(LHand, .8, .8);
				A_OverlayOffset(LHand, 2, -1, WOF_ADD);
				if(invoker.SwitchState>0)A_SetTics(0);
			}
			#### G 1{
				A_OverlayOffset(LHand, 3, 8, WOF_ADD);
				A_OverlayRotate(LHand, 1, WOF_ADD);
				A_OverlayScale(LHand, .02, .02, WOF_ADD);
			}
			Wait;
		GunLowerOpen:
			SH12 D 1 {
				A_GlovesColor();
				
				A_OverlayOffset(Lay1, -15, 2, WOF_ADD);
				A_OverlayRotate(Lay1, 2, WOF_ADD);
				A_OverlayScale(Lay1, .01, .01, WOF_ADD);
				
				Double Rot = Player.GetPSprite(Lay1).Rotation;
				
				invoker.MuzzleSmoke((-30+Rot, 0-Rot), (-15+Rot, -5-Rot), 2, 2.1);
			}
			#### ################ 1 {
				A_OverlayFlags(Lay1, PSPF_INTERPOLATE, true);
				A_OverlayOffset(Lay1, -15, 3, WOF_ADD);
				A_OverlayRotate(Lay1, 3, WOF_ADD);
				A_OverlayScale(Lay1, .01, .01, WOF_ADD);
				
				Double Rot = Player.GetPSprite(Lay1).Rotation;
				
				invoker.MuzzleSmoke((-30+Rot, 0-Rot), (-15+Rot, -5-Rot), 2, 2.1);
			}
			Stop;
		GunIdle1:
			#### # 0 {
				A_GlovesColor();
				A_OverlayPivot(Lay1, .5, 0);
				invoker.BobState = 0;
				invoker.IdleDelay = CRandom(-10, -3)*70;
				if((GetCVar("MRIntW_BersShake")>1 && FindInventory("PowerStrength"))||(Health<20 && GetCVar("MRIntW_LowHealthShake")))invoker.IdleDelay = CRandom(1, -3)*35;
			}
			#### # 0 A_JumpIf(CRandom(0, 255)<100, "GunIdle2");
			#### AAAA 1 {A_Overlayoffset(Lay1, -.15, .05, WOF_ADD);A_SetTics(CRandom(1,2));}
			#### AA 1 {A_OverlayOffset(Lay1, -.1, .05, WOF_ADD);A_OverlayRotate(Lay1, -.1, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AAA 1 {A_OverlayOffset(Lay1, .15, -.1, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_OverlayOffset(Lay1, .15, -.025, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### A 1 {A_OverlayOffset(Lay1, .1, .0, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_OverlayOffset(Lay1, .1, .025, WOF_ADD);A_OverlayRotate(Lay1, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AAA 1 {A_OverlayOffset(Lay1, .025, .05, WOF_ADD);A_OverlayRotate(Lay1, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_OverlayOffset(Lay1, -.05, -.1, WOF_ADD);A_OverlayRotate(Lay1, -.05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### A 1 {A_OverlayOffset(Lay1, .0, .05, WOF_ADD);A_OverlayRotate(Lay1, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### A 2 {
				A_OverlayRotate(Lay1, 0, WOF_INTERPOLATE);
				A_Overlayoffset(Lay1, 0, 0, WOF_INTERPOLATE);
				A_BersShake();
				A_SetTics(CRandom(1,2));
			}
			#### # 0 A_JumpIf(CRandom(0, 10)<4, "GunIdle2");
			#### # 0 A_JumpIf(CRandom(0, 40)==1, "GunIdle1");
			Goto GunWait;
		GunIdle2:
			#### A 1 {A_Overlayoffset(Lay1, .0, .05, WOF_ADD);A_OverlayRotate(Lay1, -.05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_Overlayoffset(Lay1, .05, -.1, WOF_ADD);A_OverlayRotate(Lay1, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AAA 1 {A_Overlayoffset(Lay1, -.025, .05, WOF_ADD);A_OverlayRotate(Lay1, -.05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_Overlayoffset(Lay1, -.1, .025, WOF_ADD);A_OverlayRotate(Lay1, -.05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### A 1 {A_Overlayoffset(Lay1, -.1, .0, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_Overlayoffset(Lay1, -.15, -.025, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AAA 1 {A_Overlayoffset(Lay1, -.15, -.1, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_Overlayoffset(Lay1, .1, .05, WOF_ADD);A_OverlayRotate(Lay1, .1, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AAAA 1 {A_Overlayoffset(Lay1, .15, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			Goto GunWait;
		
		Ready:
			TNT1 A 0 {
				if(MRIntW_DisplayVanilla)Player.GetPSprite(PSP_WEAPON).Sprite = GetSpriteIndex("SHT2A0");
			}
			#### A 1 {
				if(MRIntW_BobRangeZ!=0){
					Double BobZ = MRIntWeaps_Fist.GetBobZ(invoker, .5);
					A_OverlayScale(Lay1, 1+BobZ, 1+BobZ, WOF_INTERPOLATE);
					A_OverlayFlags(Lay1, PSPF_INTERPOLATE, true);
				}
				A_WeaponReady();
			}
			Wait;
		Fire:
			TNT1 A 3 {
				A_Overlay(Lay1, "GunFire");
				if(MRIntW_InstantFire)A_SetTics(0);
				
				if(MRIntW_DisplayVanilla)Player.GetPSprite(PSP_WEAPON).Sprite = GetSpriteIndex("SHT2A0");
			}
			#### A 7 {
				A_FireShotgun2();
				A_Overlay(Lay2, "GunFlash");
				A_Overlay(Lay4, "GunMuzzleFlashFlare");
				if(MRIntW_Recoil){invoker.Recoil=3;A_SetPitch(Pitch-3*MRIntW_RecoilAmount, MRIntW_RecoilRecover?0:SPF_INTERPOLATE);}//Recoil
			}
			#### A 3 {if(!MRIntW_InstantFire)A_SetTics(0);}
			#### B 7;
			#### C 7 A_CheckReload();
			#### D 7 A_StartSound ("MRIntW/SSGOpen", CHAN_AUTO, pitch:i_timescale);
			#### E 7;
			#### F 7 A_StartSound ("MRIntW/SSGLoad", CHAN_AUTO, pitch:i_timescale);
			#### G 6;
			#### H 6 {
				A_StartSound ("MRIntW/SSGClose", CHAN_WEAPON, pitch:i_timescale);
				A_Refire();
			}
			#### A 5 A_ReFire();
			Goto Ready;
			
		GunFire:
			SH12 # 0 {
				A_GlovesColor();
				A_OverlayPivot(Lay1, .5, .5);
				invoker.Reloading = false;
			}
			#### # 0 A_JumpIf(MRIntW_InstantFire, 4);
			#### A 1;
			#### A 1 A_OverlayOffset(Lay1, 0, -1, WOF_ADD);
			#### A 1 A_OverlayOffset(Lay1, 0, 3, WOF_ADD);
			#### A 1;//Shot
			#### A 1 {//Recoil
				invoker.SpriteRecoil = MRIntW_ShotgunsRecoil;
				Vector2 Pivot = (.5+CFRandom(-.15, .15)*invoker.SpriteRecoil, CFRandom(.3, .6));
				A_OverlayPivot(Lay1, Pivot.X, Pivot.Y);
				A_OverlayPivot(Lay2, Pivot.X, Pivot.Y);
				
				Float Scal = CFRandom(.3, .4)*invoker.SpriteRecoil;
				Vector2 Ofst = (-(Pivot.X-.5)*2, CFRandom(14, 18))*invoker.SpriteRecoil;
				Float Rotate = (Pivot.X-.5)*4*invoker.SpriteRecoil;
				A_OverlayScale(Lay1, Scal, Scal*1.8, WOF_ADD);
				A_OverlayOffset(Lay1, Ofst.X, Ofst.Y, WOF_ADD);
				A_OverlayRotate(Lay1, Rotate, WOF_ADD);
				
				Player.GetPSprite(Lay2).Scale = Player.GetPSprite(Lay1).Scale;
				Player.GetPSprite(Lay2).Rotation = Player.GetPSprite(Lay1).Rotation;
				Player.GetPSprite(Lay2).X = Player.GetPSprite(Lay1).X;
				Player.GetPSprite(Lay2).Y = Player.GetPSprite(Lay1).Y;
				Player.GetPSprite(Lay4).X = Player.GetPSprite(Lay2).X+125;
				Player.GetPSprite(Lay4).Y = Player.GetPSprite(Lay2).Y+90;
				
				A_FireSmoke();
				
				if(MRIntW_ScreenShake)A_Quake(0,1,1, 14, 0, .5, "", QF_SCALEDOWN|QF_WAVE, 10,10,2, rollIntensity: .25, rollwave: 10);
			}
			#### # 1{
				Float Scal = CFRandom(.07, .1)*invoker.SpriteRecoil;
				Vector2 Ofst = (-(Player.GetPSprite(Lay1).Pivot.X-.5), CFRandom(7, 10))*invoker.SpriteRecoil;
				Float Rotate = (Player.GetPSprite(Lay1).Pivot.X-.5)*2*invoker.SpriteRecoil;
				A_OverlayScale(Lay1, Scal, Scal*1.5, WOF_ADD);
				A_OverlayOffset(Lay1, Ofst.X, Ofst.Y, WOF_ADD);
				A_OverlayRotate(Lay1, Rotate, WOF_ADD);
				
				Player.GetPSprite(Lay2).Scale = Player.GetPSprite(Lay1).Scale;
				Player.GetPSprite(Lay2).Rotation = Player.GetPSprite(Lay1).Rotation;
				Player.GetPSprite(Lay2).X = Player.GetPSprite(Lay1).X;
				Player.GetPSprite(Lay2).Y = Player.GetPSprite(Lay1).Y;
				Player.GetPSprite(Lay4).X = Player.GetPSprite(Lay2).X+125;
				Player.GetPSprite(Lay4).Y = Player.GetPSprite(Lay2).Y+90;
				
				A_FireSmoke();
			}
			#### AAAA 1{//Recover
				A_OverlayFlags(Lay1, PSPF_INTERPOLATE, true);
				Float Recover = .7;
				Player.GetPSprite(Lay2).X = Player.GetPSprite(Lay1).X = Player.GetPSprite(Lay1).X*Recover;
				Player.GetPSprite(Lay2).Y = Player.GetPSprite(Lay1).Y = Player.GetPSprite(Lay1).Y*Recover;
				Player.GetPSprite(Lay2).Scale = Player.GetPSprite(Lay1).Scale = (1,1)+(Player.GetPSprite(Lay1).Scale-(1,1))*Recover;
