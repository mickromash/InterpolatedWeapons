Class MRIntWeaps_Shotgun: Shotgun Replaces Shotgun
{
	Default{
		Weapon.SlotNumber 3;
		Decal "BulletChip";
	}
	
	Const Lay1 = 2;
	Const Lay2 = PSP_FLASH+1;
	Const LHand = -PSP_FLASH;
	Const Lay3 = LHand-1;//Muzzle flash flare
	
	int BobState, IdleDelay, ShotPower;
		
	Float Recoil;
	Override Void DoEffect()
	{
		if(Recoil>0){
			Double Recover = .125*MRIntW_RecoilRecover;
			Recoil -= Recover;
			Owner.A_SetPitch(Owner.Pitch+Recover*MRIntW_RecoilAmount);
		}
		
		For(int i=0;i<Casings.Size();i++){
			if(Casings[i])DoCasing(i);
		}
		
		MuzzleSmoke();
		
		//Disabling weapon interpolation while game is loading
		Let Handler = MRIntWeaps_Handler(EventHandler.Find("MRIntWeaps_Handler"));
		if(Handler && Handler.LoadingDelay>0 && Owner.Player.FindPSprite(Lay1) && Owner.Player.FindPSprite(Lay1).CurState){
			Owner.Player.GetPSprite(Lay1).bInterpolate = false;
			Owner.Player.GetPSprite(Lay1).Y = Max(Owner.Player.GetPSprite(Lay1).Y, 0);
		}
	}
	
	Bool CustomSound;
	action void A_FireShotgun()
	{
		if(!player)
		{
			return;
		}
		
		invoker.CustomSound = CVar.GetCVar("MRIntW_ShotgunSound", players[ConsolePlayer]) && CVar.GetCVar("MRIntW_ShotgunSound", players[ConsolePlayer]).GetBool();
			
		A_StartSound(invoker.CustomSound?"MRIntW/ShotgunFireCustom":"MRIntW/ShotgunFire", CHAN_WEAPON, pitch:i_timescale);
		Weapon weap = player.ReadyWeapon;
		if (weap != null && invoker == weap && stateinfo != null && stateinfo.mStateType == STATE_Psprite)
		{
			if (!weap.DepleteAmmo (weap.bAltFire, true))
				return;
			
			player.SetPsprite(PSP_FLASH, weap.FindState('Flash'), true);
		}
		player.mo.PlayAttacking2 ();

		double pitch = BulletSlope ();
		
		invoker.ShotPower = 0;
		
		for (int i = 0; i < 7; i++)
		{
			invoker.ShotPower += GunShot(false, "BulletPuff", pitch);
		}
		
		A_FiringParticles();
		
		if(CountInv(invoker.AmmoType1)<1 && MRIntW_ReloadAnims%2==1)invoker.Reload = true;
	}
	action int GunShot(bool accurate, Class<Actor> pufftype, double pitch)
	{
		int damage = 5 * random[GunShot](1, 3);
		double ang = angle;

		if (!accurate)
		{
			ang += Random2[GunShot]() * (5.625 / 256);

			if (GetCVar ("vertspread") && !sv_novertspread)
			{
				pitch += Random2[GunShot]() * (3.549 / 256);
			}
		}

		LineAttack(ang, PLAYERMISSILERANGE, pitch, damage, 'Hitscan', pufftype);
		
		Return Damage;
	}
	
	Action Void A_GlovesColor(int Trans=0)
	{
		Let Feest = MRIntWeaps_Fist(FindInventory("MRIntWeaps_Fist"));
		if(!Feest)Return;
		
		Switch(Trans)
		{
			Case 1:
				Player.GetPSprite(OverlayId()).Translation = Feest.GlovesTrans;
				Break;
			Case 0:
				Player.GetPSprite(OverlayId()).Translation = Feest.PistolGlovesTrans;
				Break;
		}
	}
	
	Override Void PostBeginPlay()
	{
		Super.PostBeginPlay();
		if(MRIntW_ReloadAnims>1)Reload = true;
	}
	
	Bool Reload;
	Double PumpRotation, SpriteRecoil;
	int SwitchAnim, SwitchState;
	Vector2 SelPos;
	Double SelFrame;
	
	States{
		GunRaise:
			TNT1 A 0 A_JumpIf(invoker.Reload, "GunRaiseReload");
			TNT1 A 1{
				invoker.SwitchAnim = CRandom(0, 1);
			}
			TNT1 AAA 1 {
				A_GlovesColor();
				A_OverlayFlags(Lay1, PSPF_ADDWEAPON , false);
				if(invoker.SwitchAnim){
					A_OverlayPivot(Lay1, .5, 1);
					A_OverlayScale(Lay1, 1, 1);
					A_OverlayOffset(Lay1, 3+5+5 + 5*6, 32-5-2-2+11*7.7);
					A_OverlayRotate(Lay1, -.2-.2 -4*6.8);
				}
				else {
					A_OverlayPivot(Lay1, .5, 0);
					A_OverlayOffset(Lay1, 54, 89);
					A_OverlayScale(Lay1, 1.2, 1.2);
					A_OverlayRotate(Lay1, -10.5);
				}
				
				invoker.SwitchState = 10;
			}
			SH1G A 1{
				if(invoker.SwitchAnim){
					Player.GetPSprite(Lay1).Frame = 25;
					A_Overlay(LHand, "LeftHandRaise");
				}
			}
			#### ####### 1 {
				if(invoker.SwitchAnim){
					A_OverlayOffset(Lay1, -5, -11, WOF_ADD);
					A_OverlayRotate(Lay1, 4, WOF_ADD);
				}
				else {
					A_OverlayOffset(Lay1, -7, -9, WOF_ADD);
					A_OverlayScale(Lay1, -.02, -.02, WOF_ADD);
					A_OverlayRotate(Lay1, 1.2, WOF_ADD);
				}
				
				invoker.SwitchState--;
			}
			#### # 1 {
				if(invoker.SwitchAnim){
					A_OverlayOffset(Lay1, -5, -2, WOF_ADD);
					A_OverlayRotate(Lay1, .2, WOF_ADD);
				}
				else {
					A_OverlayOffset(Lay1, -4, 4, WOF_ADD);
					A_OverlayScale(Lay1, -.02, -.02, WOF_ADD);
					A_OverlayRotate(Lay1, 1.4, WOF_ADD);
				}
				
				invoker.SwitchState--;
			}
			
			#### # 1 {
				if(invoker.SwitchAnim){
					A_OverlayOffset(Lay1, 0, 32, WOF_INTERPOLATE);
