			}
			#### A 1 {
				invoker.SwitchState=0;
				A_OverlayFlags(Lay1, PSPF_INTERPOLATE, false);
				A_OverlayOffset(Lay1, CFRandom(-2, 2), CFRandom(-1, 3)+32, WOF_INTERPOLATE);
			}
			#### A 1 {
				A_OverlayFlags(Lay1, PSPF_ADDWEAPON , true);
				Player.GetPSprite(Lay1).OldY -= 32;
				Player.GetPSprite(Lay1).Y -= 32;
