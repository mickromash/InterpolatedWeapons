					Vector3 Inten, Freak;
					Inten = (0, .1*Intens, .2*Intens);
					Freak = (0,10,10);
					
					Vector3 IntenR, FreakR;
					
					IntenR = (AngleToVector(Angle, Inten.X)*Cos(Pitch), Inten.Z*Cos(Pitch));
					IntenR.XY += AngleToVector(Angle+90, Inten.Y);
					IntenR.XY += AngleToVector(Angle, Inten.Z*Sin(Pitch));
					IntenR.Z += Inten.X*Sin(Pitch);
					
					FreakR = (AngleToVector(Angle, Freak.X)*Cos(Pitch), Freak.Z*Cos(Pitch));
					FreakR.XY += AngleToVector(Angle+90, Freak.Y);
					FreakR.XY += AngleToVector(Angle, Freak.Z*Sin(Pitch));
					FreakR.Z += Freak.X*Sin(Pitch);
					
					A_Quake(IntenR.X, IntenR.Y, IntenR.Z, 6+Intens*2, 0, .5, "", QF_SCALEDOWN|QF_WAVE, FreakR.X, FreakR.Y, FreakR.Z, rollIntensity: .1*Intens, rollwave: 10);
