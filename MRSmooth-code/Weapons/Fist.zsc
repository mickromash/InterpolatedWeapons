				else invoker.SecndHand = (Player.GetPSprite(OverlayId()).X, Player.GetPSprite(OverlayId()).Y);
			}
			#### # 0 A_JumpIf(GetCVar("MRIntW_PunchingFist")>0 && !invoker.SecondFist, "Null");
			#### # 2 A_OverlayFlags(OverlayId(), PSPF_INTERPOLATE, false);
			#### C 1 {
				A_OverlayOffset(OverlayId(), -30, 43);
				A_OverlayRotate(OverlayId(), 0);
				A_OverlayScale(OverlayId(), 1.1, 1.1);
				invoker.MainHand = (Player.GetPSprite(OverlayId()).X, Player.GetPSprite(OverlayId()).Y);
			}
			#### CC 1 {
				A_OverlayFlags(OverlayId(), PSPF_INTERPOLATE, true);
				A_OverlayScale(OverlayId(), -.05, -.05, WOF_ADD);
				A_OverlayOffset(OverlayId(), 15, -20, WOF_ADD);
			}
			#### # 0 {
				A_Overlayoffset(OverlayId(), 0, 0, WOF_INTERPOLATE);
				invoker.MainHand = (Player.GetPSprite(OverlayId()).X, Player.GetPSprite(OverlayId()).Y);
			}
			Goto MainHandWait;
		MainHandPunchBerserkThru://If killing an enemy (if second fist is on or got berserk)
			#### # 0 A_OverlayFlags(OverlayId(), PSPF_INTERPOLATE, false);
			#### CC 2 {
				A_OverlayOffset(OverlayId(), -30, 43);
				A_OverlayRotate(OverlayId(), 0);
				A_OverlayScale(OverlayId(), 1.1, 1.1);
				invoker.MainHand = (Player.GetPSprite(OverlayId()).X, Player.GetPSprite(OverlayId()).Y);
				Player.GetPSprite(OverlayId()).Translation = invoker.GlovesTrans;
			}
			#### CC 1 {
				A_OverlayFlags(OverlayId(), PSPF_INTERPOLATE, true);
				A_OverlayScale(OverlayId(), -.05, -.05, WOF_ADD);
				A_OverlayOffset(OverlayId(), 15, -20, WOF_ADD);
			}
			#### # 0 {
				A_Overlayoffset(OverlayId(), 0, 0, WOF_INTERPOLATE);
				invoker.MainHand = (Player.GetPSprite(OverlayId()).X, Player.GetPSprite(OverlayId()).Y);
			}
			Goto MainHandWait;
			
		GunIdle1://Idle animation 1
			#### # 0 {
				A_OverlayPivot(SecndLay, .5, 1);
				invoker.BobState = 0;
				invoker.IdleDelay = CRandom(-10, -3)*70;
				if((CountInv("PowerStrength") && GetCVar("MRIntW_BersShake"))||(Health<20 && GetCVar("MRIntW_LowHealthShake")))invoker.IdleDelay = CRandom(1, -3)*35;
				Player.GetPSprite(SecndLay).Translation = invoker.GlovesTrans;
			}
			#### # 0 A_JumpIf(CRandom(0, 255)<100, "GunIdle2");
			#### #### 1 {A_Overlayoffset(SecndLay, -.15, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### ## 1 {A_OverlayOffset(SecndLay, -.1, .05, WOF_ADD);A_OverlayRotate(SecndLay, -.1, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### ### 1 {A_OverlayOffset(SecndLay, .15, -.1, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### ## 1 {A_OverlayOffset(SecndLay, .15, -.025, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### # 1 {A_OverlayOffset(SecndLay, .1, .0, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### ## 1 {A_OverlayOffset(SecndLay, .1, .025, WOF_ADD);A_OverlayRotate(SecndLay, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### ### 1 {A_OverlayOffset(SecndLay, .025, .05, WOF_ADD);A_OverlayRotate(SecndLay, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### ## 1 {A_OverlayOffset(SecndLay, -.05, -.1, WOF_ADD);A_OverlayRotate(SecndLay, -.05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### # 1 {A_OverlayOffset(SecndLay, .0, .05, WOF_ADD);A_OverlayRotate(SecndLay, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### # 2 {
				A_OverlayRotate(SecndLay, 0, WOF_INTERPOLATE);
				A_Overlayoffset(SecndLay, 0, 0, WOF_INTERPOLATE);
				A_SetTics(CRandom(1,2));
			}
			#### # 0 A_JumpIf(CRandom(0, 10)<4, "GunIdle2");
			#### # 0 A_JumpIf(CRandom(0, 40)==1, "GunIdle1");
			Goto SecndHandWait;
		GunIdle2://Idle animation 2
			#### A 1 {A_Overlayoffset(SecndLay, .0, .05, WOF_ADD);A_OverlayRotate(SecndLay, -.05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_Overlayoffset(SecndLay, .05, -.1, WOF_ADD);A_OverlayRotate(SecndLay, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AAA 1 {A_Overlayoffset(SecndLay, -.025, .05, WOF_ADD);A_OverlayRotate(SecndLay, -.05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_Overlayoffset(SecndLay, -.1, .025, WOF_ADD);A_OverlayRotate(SecndLay, -.05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### A 1 {A_Overlayoffset(SecndLay, -.1, .0, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_Overlayoffset(SecndLay, -.15, -.025, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AAA 1 {A_Overlayoffset(SecndLay, -.15, -.1, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AA 1 {A_Overlayoffset(SecndLay, .1, .05, WOF_ADD);A_OverlayRotate(SecndLay, .1, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			#### AAAA 1 {A_Overlayoffset(SecndLay, .15, .05, WOF_ADD);A_BersShake(); A_SetTics(CRandom(1,2));}
			Goto SecndHandWait;
		
		//Default gun states
		Select:
			TNT1 A 0 {
				A_Overlay(SecndLay, "SecndHandRaise");
				Player.GetPSprite(PSP_WEAPON).Y = WEAPONBOTTOM;
				
				if(MRIntW_DisplayVanilla)Player.GetPSprite(PSP_WEAPON).Sprite = GetSpriteIndex("PUNGA0");
			}
		Raise:
			#### A 1 A_Raise();
			Loop;
		Deselect:
			TNT1 A 0 {
				if(Health<1){
					A_Overlay(SecndLay, "SecndHandDie");
					if(GetCVar("MRIntW_SecondFist")||(CountInv("PowerStrength") && GetCVar("MRIntW_BersShake")))A_Overlay(MainLay, "MainHandDie");
					Return;
				}
				A_Overlay(SecndLay, "SecndHandLower");
				Player.GetPSprite(PSP_WEAPON).Y = 32;
				
				if(MRIntW_DisplayVanilla)Player.GetPSprite(PSP_WEAPON).Sprite = GetSpriteIndex("PUNGA0");
			}
		Lower:
			#### A 1 A_Lower();
			Loop;
			
		Ready:
			TNT1 A 0 {
				A_OverlayPivot(MainLay, .5, .5);
				A_OverlayPivot(SecndLay, .5, .5);
				
				if(MRIntW_DisplayVanilla)Player.GetPSprite(PSP_WEAPON).Sprite = GetSpriteIndex("PUNGA0");
			}
			#### A 1 {
				A_WeaponReady();
				
				if(MRIntW_BobRangeZ!=0){
					Double BobZ = invoker.GetBobZ(invoker, .5);
					A_OverlayScale(SecndLay, 1+BobZ, 1+BobZ, WOF_INTERPOLATE);
					A_OverlayScale(MainLay, 1+BobZ, 1+BobZ, WOF_INTERPOLATE);
					A_OverlayFlags(MainLay, PSPF_INTERPOLATE, true);
					A_OverlayFlags(SecndLay, PSPF_INTERPOLATE, true);
				}
			}
			Wait;
		Fire://4, 4 Punch, 5, 4, 5 Refire
			TNT1 A 0 {
				A_Overlay(SecndLay, "SecndHandLowerFast");
				A_SelectPunchingFist();
				if(!MRIntW_BetterAlert)A_AlertMonsters();
				
				if(MRIntW_DisplayVanilla)Player.GetPSprite(PSP_WEAPON).Sprite = GetSpriteIndex("PUNGA0");
			}
			#### B 4;
			#### C 4 {
				FLineTraceData Punch;
				
				Double PZ = player.mo.height * 0.5 - player.mo.floorclip + player.mo.AttackZOffset*player.crouchFactor;
				LineTrace(Angle, 64, Pitch, 0, PZ, data:Punch);
				
				A_Punch();
				if(Punch.HitActor){
					invoker.HitActor = true;
					if(GetCVar("MRIntW_FinishPunch") && (FindInventory("PowerStrength")||GetCVar("MRIntW_FinishPunch")>1) &&
						Punch.HitActor.Health<1 && CFRandom(.1, 1)<=GetCVar("MRIntW_FinishPunchChance")
					)
						Player.SetPsprite((GetCVar("MRIntW_PunchingFist")>0 && !invoker.SecondFist)?SecndLay:MainLay, invoker.FindState("MainHandPunchThru"));
						
					if(MRIntW_ScreenShake>1){
						Float Intens = 1;
						if(CountInv("PowerStrength"))Intens = 2;
						A_Quake(0,.2*Intens,.3*Intens, 4+Intens*2, 0, .5, "", QF_SCALEDOWN|QF_WAVE, 0,14,14, rollIntensity: .15*Intens, rollwave: 14);
					}
					Return;
				}
				if(Punch.HitType!=TRACE_HitNone){
					invoker.HitWall = true;
					String Snd = "MRIntW/FistPunchWallKnuckles";
					if(GetCVar("MRIntW_PunchingFist")>0 && !invoker.SecondFist) Snd = "MRIntW/FistPunchWall";
					A_StartSound(Snd, CHAN_AUTO, pitch: CFRandom(.95, 1.05)*i_timescale);
					if(GetCVar("MRIntW_SurfacePunchRecoil") && FindInventory("PowerStrength"))
					{
						Double Strength = CFRandom(.5, 1);
						
						Vel.XY += AngleToVector(Angle+180, Strength)*Cos(abs(Pitch));
						Vel.Z += Strength*2*Sin(Pitch);
					}
					
					if(MRIntW_ScreenShake>1){
						Float Intens = 1;
						if(CountInv("PowerStrength"))Intens = 2;
						A_Quake(0,.4*Intens,.2*Intens, 8, 0, .5, "", QF_SCALEDOWN|QF_WAVE, 0,8,8, rollIntensity: .2*Intens, rollwave: 8);
					}
				}
			}
			#### D 5;
			#### C 4;
			#### B 5 {A_Refire();if(!(Player.OldButtons&BT_ATTACK||Player.Cmd.Buttons&BT_ATTACK))A_Overlay(SecndLay, "SecndHandUp");}
			#### A 0 {
				if(!InStateSequence(Player.GetPSprite(SecndLay).CurState, invoker.FindState("SecndHandUp")))A_Overlay(SecndLay, "SecndHandUp");
			}
			Goto Ready;
		//Caching sprites
		Sprites:
			PUN3 A 0;
			Stop;
	}
	
	Action Void A_IdleAnimation(int Lay = 2)//Idle hand bobbing
	{
		Bool Bers = (GetCVar("MRIntW_BersShake") && FindInventory("PowerStrength"))||(Health<20 && GetCVar("MRIntW_LowHealthShake"));
		Float Mult = (Bers?2:1);
		if(MRIntW_BobRangeZ==0)A_OverlayFlags(Lay, PSPF_INTERPOLATE, false);
		if(Lay!=MainLay){
			if(invoker.BobState>=0){
				A_OverlayOffset(Lay, CFRandom(-.005, .015)*Mult, CFRandom(.01, .02)*Mult, WOF_ADD);
				if(invoker.BobState>90||Player.GetPSprite(Lay).Y>1.35){invoker.BobState = -invoker.BobState;}
				else invoker.BobState+=Mult;
			}
			else {
				A_OverlayOffset(Lay, -CFRandom(-.005, .015)*Mult, -CFRandom(.01, .02)*Mult, WOF_ADD);
				if(Player.GetPSprite(Lay).Y<0){A_OverlayOffset(Lay, 0, 0, WOF_INTERPOLATE);invoker.BobState = 0;}
				else if(!(invoker.BobState>=-1&&Player.GetPSprite(Lay).Y>0))invoker.BobState+=Mult;
			}
			if(Bers && GetAge()%2==0){//Shaking hand if got berserk
				if(MRIntW_BobRangeZ==0){
					A_OverlayPivot(Lay, .2, .7);
					Player.GetPSprite(Lay).Scale = (CFRandom(.99, 1.01), CFRandom(.99, 1.01));
				}
				else A_OverlayScale(Lay, CFRandom(-.02, .02), CFRandom(-.02, .02), WOF_ADD);
				A_OverlayOffset(Lay, CFRandom(-.5, .5), 0, WOF_INTERPOLATE|WOF_KEEPY);
				Player.GetPSprite(Lay).Y += CFRandom(-.5, .5);
				if(Player.GetPSprite(Lay).Y<0){Player.GetPSprite(Lay).Y = 0;invoker.BobState = 0;}
				if(Player.GetPSprite(Lay).Y>1.35){Player.GetPSprite(Lay).Y = 1.35;invoker.BobState = -90;}
				Player.GetPSprite(Lay).Rotation = CFRandom(-.1, .1);
			}
			if(GetCVar("MRIntW_IdleAnims"))invoker.IdleDelay++;
		}
		
		else {
			if(invoker.BobState>=0){
				A_OverlayOffset(Lay, CFRandom(-.005, .015)*Mult, CFRandom(.01, .02)*Mult, WOF_ADD);
			}
			else {
				A_OverlayOffset(Lay, -CFRandom(-.005, .015)*Mult, -CFRandom(.01, .02)*Mult, WOF_ADD);
				if(Player.GetPSprite(Lay).Y<0)A_OverlayOffset(Lay, 0, 0, WOF_INTERPOLATE);
			}
			if(Bers && GetAge()%2==0){//Shaking hand if got berserk
				if(MRIntW_BobRangeZ==0)A_OverlayPivot(Lay, .8, .5);
				A_OverlayOffset(Lay, CFRandom(-.5, .5)/Player.GetPSprite(Lay).Scale.X, 0, WOF_INTERPOLATE|WOF_KEEPY);
				Player.GetPSprite(Lay).Y += CFRandom(-.5, .5);
				if(Player.GetPSprite(Lay).Y<0)Player.GetPSprite(Lay).Y = 0;
				if(Player.GetPSprite(Lay).Y>1.35)Player.GetPSprite(Lay).Y = 1.35;
				Player.GetPSprite(Lay).Rotation = CFRandom(-.1, .1);
			}
		}
	}
	
	Clearscope Static Double GetBobZ(Weapon Weap, Double Center = .5)
	{
		PlayerPawn Plr = PlayerPawn(Weap.Owner);
		
		Double Range = MRIntW_BobRangeZ;
		int bobstyle = Weap.BobStyle;
		double angle = (Weap.BobSpeed*128 * Plr.player.GetWBobSpeed() * 35 /	TICRATE*(Level.maptime)) * (360. / 8192.);

		// [RH] Smooth transitions between bobbing and not-bobbing frames.
		// This also fixes the bug where you can "stick" a weapon off-center by
		// shooting it when it's at the peak of its swing.
		Double R;

		// The weapon bobbing intensity while firing can be adjusted by the player.
		double BobIntensity = ((Plr.player.WeaponState & WF_WEAPONBOBBING) ? 1. : Plr.player.GetWBobFire())*.01;

		if (Plr.curbob != 0)
		{
			double bobVal = Plr.player.bob;
			
			bobVal = Plr.prevBob;
			//[SP] Added in decorate player.viewbob checks
			double bob = (bobVal * BobIntensity * Range * Plr.ViewBob);
			switch (bobstyle)
			{
			case Bob_Normal:
				R = Bob * (Center - abs(Sin(angle)));
				break;

			case Bob_Inverse:
				R = bob * (Center - abs(sin(angle)));
				break;

			case Bob_Alpha:
				R = bob * (Center - abs(sin(angle)));
				break;

			case Bob_InverseAlpha:
				R = bob * (Center - abs(sin(angle)));
				break;

			case Bob_Smooth:
				R = 0.5f * (bob * (Center - (cos(angle * 2))));
				break;

			case Bob_InverseSmooth:
				R = 0.5f * (bob * (Center + (cos(angle * 2))));
			}
		}
		else
		{
			r = 0;
		}
		
		Return R;
	}
	
	Action Void A_BersShake()
	{
		if((CountInv("PowerStrength") && GetCVar("MRIntW_BersShake"))||(Health<20 && GetCVar("MRIntW_LowHealthShake")))A_OverlayOffset(SecndLay, CFRandom(-.5, .5), CFRandom(-.5, .5), WOF_ADD);
	}
	
	Action Void A_Quake(Float X, Float Y, Float Z, int TermTicks=0, int DmgTicks=0, Double Dist=.25, String QuakeSound="", int Flags=0, Float XW=0, Float YW=0, Float ZW=0, Float rollintensity=0, int rollwave=0)
	{
		Vector3 IntenR, FreakR;
		
		IntenR = (AngleToVector(Angle, Y)*Cos(Pitch), Z*Cos(Pitch));
		IntenR.XY += AngleToVector(Angle+90, X);
		IntenR.XY += AngleToVector(Angle, Z*Sin(Pitch));
		IntenR.Z += Y*Sin(Pitch);
		
		FreakR = (AngleToVector(Angle, YW)*Cos(Pitch), ZW*Cos(Pitch));
		FreakR.XY += AngleToVector(Angle+90, XW);
		FreakR.XY += AngleToVector(Angle, ZW*Sin(Pitch));
		FreakR.Z += YW*Sin(Pitch);
			
		A_QuakeEx(Abs(IntenR.X), Abs(IntenR.Y), Abs(IntenR.Z), TermTicks, DmgTicks, Dist, QuakeSound, Flags, Abs(FreakR.X), Abs(FreakR.Y), Abs(FreakR.Z), rollIntensity: rollintensity, rollwave: rollwave);
	}
}

Class MRIntWeaps_FistSelector: CustomInventory
{
	Default
	{
		+INVENTORY.ALWAYSPICKUP
		+Inventory.Quiet
		Inventory.PickupMessage "";
		Inventory.PickupSound "";
	}
	States
	{
	Spawn:
		TNT1 A -1;
		Stop;
	Pickup:
		TNT1 A 0 {A_SelectWeapon("MRIntWeaps_Fist");invoker.Destroy();}
		Stop;
	}
}