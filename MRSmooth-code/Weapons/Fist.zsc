Class MRIntWeaps_Fist: Fist Replaces Fist
{
	Default{
		Weapon.SlotNumber 1;
		+Weapon.NOALERT
	}
	
	Const SecndLay = 2;//Second hand
	Const MainLay = 3;//Main hand
	
	Double CurBounce, BounceStrength;
	Bool Bouncing;
	int DamageShake, PlrLastHealth;
	Vector2 FireBob;
	
	Override Void DoEffect()
	{
		//Disabling weapon interpolation while game is loading
		Let Handler = MRIntWeaps_Handler(EventHandler.Find("MRIntWeaps_Handler"));
		if(!Handler)Return;

		if(Handler.LoadingDelay>0){
			if(Owner.Player.FindPSprite(MainLay) && Owner.Player.FindPSprite(MainLay).CurState){
				Owner.Player.GetPSprite(MainLay).bInterpolate = false;
				Owner.Player.GetPSprite(MainLay).Y = Max(Owner.Player.GetPSprite(MainLay).Y, 0);
				Owner.Player.GetPSprite(SecndLay).bInterpolate = false;
				Owner.Player.GetPSprite(SecndLay).Y = Max(Owner.Player.GetPSprite(SecndLay).Y, 0);
			}
			Handler.LoadingDelay--;
		}
		
		if(!Owner.Player)Return;

		UpdateGloves();
		
		Let Weap = Owner.Player.ReadyWeapon;
		if(!Weap||!Owner.Player.FindPSprite(PSP_WEAPON))Return;
		Let PSP = Owner.Player.GetPSprite(PSP_WEAPON);
		Bool Allowed = (!InStateSequence(PSP.curState, Weap.GetDownState()) && !InStateSequence(PSP.CurState, Weap.FindState("Select")));
		
		Weap.BobStyle = MRIntW_BobStyle;
		Weap.BobRangeX = MRIntW_BobRangeX;
		Weap.BobRangeY = MRIntW_BobRangeY;
		
		if(MRIntW_VanillaFireBob){
			if(InStateSequence(PSP.CurState, Weap.FindState("Fire"))){
				PSP.X = FireBob.X;
				PSP.Y = 32+FireBob.Y;
			}
			else FireBob = PlayerPawn(Owner).BobWeapon(2);
		}
		
		if(MRIntW_DamageShake){
		
			if(DamageShake>0){
				Double Shake = DamageShake;
				Shake *= .1;
				Owner.Player.GetPSprite(PSP_WEAPON).X = GetAge()%2==0?Shake:-Shake;
				if(Allowed)Owner.Player.GetPSprite(PSP_WEAPON).Y = 32+Shake*CFRandom(0, 1);
				DamageShake -= 4;
				if(DamageShake<0)DamageShake = 0;
			}
			//else {Owner.Player.GetPSprite(PSP_WEAPON).X = 0;if(Allowed)Owner.Player.GetPSprite(PSP_WEAPON).Y = 32;}
			
			if(Owner.Health<PlrLastHealth){
				DamageShake = PlrLastHealth - Owner.Health;
			}
			
			PlrLastHealth = Owner.Health;
		}
		
		if(!MRIntW_Bounce)Return;
		
		Bouncing = false;
		
		if(Owner.Pos.Z > Owner.FloorZ){
			BounceStrength = Owner.Vel.Z;
			CurBounce += (BounceStrength - CurBounce)*.5;
			CurBounce = Clamp(CurBounce, -abs(Weap.MissileHeight), 20);
			Bouncing = true;
		}
		else if(abs(BounceStrength)>0){
			if(CurBounce<-BounceStrength)CurBounce -= BounceStrength*.5;
			
			else {
				BounceStrength *= .7;
				if(abs(BounceStrength)<.05)BounceStrength = 0;
				CurBounce = -BounceStrength;
			}
			
			Bouncing = true;
		}
		
		if(Bouncing && Allowed){
			Double Bounce = CurBounce*.5;
			if(Bounce<0)Bounce /= Max(1, Weap.MissileHeight/32);
			PSP.Y = 32 + CurBounce*.5;
		}
	}
	
	Action Void A_SelectPunchingFist()
	{
		Switch(GetCVar("MRIntW_PunchingFist"))
		{
			Case 0://Main fist
				A_Overlay(MainLay, "MainHandPunch");
				invoker.SecondFist = true;
				Return;
			Case 1://Randomly main or second fist
				if(CFRandom(0, 10)>4){invoker.SecondFist = true;A_Overlay(MainLay, "MainHandPunch");}
				else {invoker.SecondFist = false;A_Overlay(SecndLay, "SecndHandPunch");}
				Return;
			Case 2://Switch
				invoker.SecondFist = !invoker.SecondFist;
				if(invoker.SecondFist)A_Overlay(MainLay, "MainHandPunch");
				else A_Overlay(SecndLay, "SecndHandPunch");
				Return;
			Case 3://According to camera and player movement
				if(GetCVar("MRIntW_RightPunch")?Player.Cmd.Yaw<0:Player.Cmd.Yaw>0){invoker.SecondFist = false;A_Overlay(SecndLay, "SecndHandPunch");Return;}
				else if(GetCVar("MRIntW_RightPunch")?Player.Cmd.Yaw>0:Player.Cmd.Yaw<0){invoker.SecondFist = true;A_Overlay(MainLay, "MainHandPunch");Return;}
				
				if(GetCVar("MRIntW_RightPunch")?Player.Cmd.SideMove<0:Player.Cmd.SideMove>0){invoker.SecondFist = true;A_Overlay(MainLay, "MainHandPunch");Return;}
				else if(GetCVar("MRIntW_RightPunch")?Player.Cmd.SideMove>0:Player.Cmd.SideMove<0){invoker.SecondFist = false;A_Overlay(SecndLay, "SecndHandPunch");Return;}
				
				invoker.SecondFist = !invoker.SecondFist;
				if(invoker.SecondFist)A_Overlay(MainLay, "MainHandPunch");
				else A_Overlay(SecndLay, "SecndHandPunch");
				Return;
		}
	}
	
	Action Void A_SetHandsSprite()
	{
		if(GetCVar("MRIntW_BareHands"))Player.GetPSprite(OverlayId()).Sprite = GetSpriteIndex("PUN3A0");
	}
	
	int BobState, IdleDelay, SwitchAnim;
	Vector2 SecndHand, MainHand;
	Bool HitWall, HitActor, SecondFist;
	
	Const SelL = 1;
	Const SelM = 2;
	Const SelRL = 4;
	Const SelRR = 8;
	Const SelGrow = 16;
	Action Void A_SetSwitchAnim()
	{
		invoker.SwitchAnim = 0;
		Switch(CRandom(0, 4))
		{
			Case 1:
				invoker.SwitchAnim |= SelL;
				if(CRandom(5, 8)==6)invoker.SwitchAnim |= SelRR;
				Break;
			Case 2:
				invoker.SwitchAnim |= SelM;
				int Rand = CRandom(5, 8);
				if(Rand==6)invoker.SwitchAnim |= SelRL;
				else if(Rand==7)invoker.SwitchAnim |= SelRR;
				Break;
			Default:
				if(CRandom(5, 8)==6)invoker.SwitchAnim |= SelRL;
				Break;
		}
		if(!(invoker.SwitchAnim&SelRR||invoker.SwitchAnim&SelRL) && CRandom(0, 4)>0)invoker.SwitchAnim|=SelGrow;
	}
	
	States{
		SecndHandRaise://Select animation
			#### # 0 A_JumpIf(GetCVar("MRIntW_BareHands") && GetCVar("MRIntW_GloveStrip"), "TakeOffGloves");
			#### # 0 {if(GetCVar("MRIntW_SecondFist")||(CountInv("PowerStrength") && GetCVar("MRIntW_BersShake")))A_Overlay(MainLay, "MainHandRaise");}
			TNT1 A 0 A_SetSwitchAnim();
			TNT1 AAAAA 1 {
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(OverlayId(), PSPF_MIRROR|PSPF_FLIP, true);
				A_OverlayFlags(SecndLay, PSPF_ADDWEAPON , false);
				int XPos = 40;
				Float Pivot = 0;
				if(invoker.SwitchAnim&SelM){XPos = 0;Pivot = .5;}
				else if(invoker.SwitchAnim&SelL){XPos = -20;Pivot = 1;}
				A_OverlayPivot(SecndLay, Pivot, 0);
				A_OverlayOffset(SecndLay, XPos, 75);
				Float ScalY = 1.7;
				if(invoker.SwitchAnim&SelGrow)ScalY = 1.1;
				A_OverlayScale(SecndLay, 1.7, ScalY);
				int Rot;
				if(invoker.SwitchAnim&SelRL)Rot = -10;
				else if(invoker.SwitchAnim&SelRR)Rot = 10;
				A_OverlayRotate(SecndLay, Rot);
				Player.GetPSprite(SecndLay).Translation = invoker.GlovesTrans;
			}
			PUN1 A 1 A_SetHandsSprite();
			#### AAAAAAAA 1 {
				int XPos = 40;
				Float Rot;
				if(invoker.SwitchAnim&SelM)XPos = 0;
				else if(invoker.SwitchAnim&SelL)XPos = -20;
				
				A_OverlayFlags(SecndLay, PSPF_INTERPOLATE, true);
				A_OverlayOffset(SecndLay, -XPos*.11, -4.5, WOF_ADD);
				Float ScalY = -.08;
				if(invoker.SwitchAnim&SelGrow)ScalY = -.0125;
				A_OverlayScale(SecndLay, -.08, ScalY, WOF_ADD);
				if(invoker.SwitchAnim&SelRL)Player.GetPSprite(SecndLay).Rotation += Min(abs(Player.GetPSprite(SecndLay).Rotation), 1.1);
				else if(invoker.SwitchAnim&SelRR)Player.GetPSprite(SecndLay).Rotation -= Min(Player.GetPSprite(SecndLay).Rotation, 1.1);
			}
			#### A 1 {
				A_OverlayFlags(SecndLay, PSPF_ADDWEAPON , true);
				int XPos = 3;
				if(invoker.SwitchAnim&SelM)XPos = 0;
				else if(invoker.SwitchAnim&SelL)XPos = -3;
				A_OverlayRotate(SecndLay, 0);
				A_OverlayOffset(SecndLay, XPos, CFRandom(-3, -1));
				A_OverlayScale(SecndLay, 1, 1);
			}
		SecndHandWait://Ready animation start
			#### # 0 {
				A_OverlayPivot(SecndLay, .5, .5);
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(OverlayId(), PSPF_MIRROR|PSPF_FLIP, true);
				A_OverlayFlags(SecndLay, PSPF_INTERPOLATE, false);
				A_OverlayOffset(SecndLay, 0, 0, WOF_INTERPOLATE);
				Player.GetPSprite(SecndLay).Translation = invoker.GlovesTrans;
				invoker.SecndHand = (0,0);
			}
			PUN1 A 2 A_SetHandsSprite();
		SecndHandWaitLoop://Ready animation
			#### A 1 A_IdleAnimation(SecndLay);
			#### # 0 {
				A_OverlayFlags(SecndLay, PSPF_INTERPOLATE, true);
				if(GetCVar("MRIntW_SecondFist")||(CountInv("PowerStrength") && GetCVar("MRIntW_BersShake")))A_Overlay(MainLay, "MainHandUp", true);
				Player.GetPSprite(SecndLay).Translation = invoker.GlovesTrans;
			}
			#### # 0 A_JumpIf(invoker.IdleDelay>35 && abs(invoker.BobState)<2, "GunIdle1");
			Loop;
		SecndHandLower://Deselect animation
			#### # 0 A_JumpIf(GetCVar("MRIntW_BareHands") && GetCVar("MRIntW_GloveStrip"), "TakeOnGloves");
			PUN1 A 1{
				invoker.SwitchAnim = CRandom(1, 4);
				
				if(GetCVar("MRIntW_SecondFist")||(CountInv("PowerStrength") && GetCVar("MRIntW_BersShake")))A_Overlay(MainLay, "MainHandLower");
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(OverlayId(), PSPF_MIRROR|PSPF_FLIP, true);
				A_SetHandsSprite();
				A_OverlayFlags(SecndLay, PSPF_ADDWEAPON, false);
				A_OverlayPivot(SecndLay, (invoker.SwitchAnim%2==0)?1:0, invoker.SwitchAnim>2?0:1);
				A_OverlayOffset(SecndLay, 0, Player.GetPSprite(PSP_WEAPON).Y);
				A_OverlayScale(SecndLay, 1, 1);
				Player.GetPSprite(SecndLay).Translation = invoker.GlovesTrans;
				
			}
			#### A 1 {
				A_OverlayOffset(SecndLay, (invoker.SwitchAnim%2==0)?-6:6, invoker.SwitchAnim>2?4:0, WOF_ADD);
				A_OverlayScale(SecndLay, invoker.SwitchAnim>2?CFRandom(.05, .09):-.05, invoker.SwitchAnim>2?.05:-CFRandom(.05, .09), WOF_ADD);
				A_OverlayRotate(SecndLay, (invoker.SwitchAnim%2==0)?3:-3, WOF_ADD);
			}
			Wait;
		SecndHandLowerFast://Before punching
			PUN1 A 1 {
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(OverlayId(), PSPF_MIRROR|PSPF_FLIP, true);
				A_OverlayPivot(SecndLay, 0, 0);
				A_OverlayScale(SecndLay, 1, 1, WOF_INTERPOLATE);
				if(Player.FindPSprite(MainLay))A_OverlayScale(MainLay, 1, 1, WOF_INTERPOLATE);
				A_OverlayOffset(SecndLay, invoker.SecndHand.X, invoker.SecndHand.Y);
				A_SetHandsSprite();
				Player.GetPSprite(SecndLay).Translation = invoker.GlovesTrans;
			}
			#### AAA 1 {
				A_OverlayFlags(SecndLay, PSPF_INTERPOLATE, true);
				A_OverlayOffset(SecndLay, 15, 15, WOF_ADD);
				A_OverlayScale(SecndLay, .05, .05, WOF_ADD);
				invoker.SecndHand = (Player.GetPSprite(SecndLay).X, Player.GetPSprite(SecndLay).Y);
			}
			Stop;
		
		TakeOffGloves://Special select animation
			PUN3 A 1{
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(OverlayId(), PSPF_MIRROR|PSPF_FLIP, true);
				A_OverlayPivot(SecndLay, 0, 0);
				A_OverlayOffset(SecndLay, -20, 125);
				A_OverlayScale(SecndLay, .9, .9);
				A_OverlayRotate(SecndLay, 30);
				
				A_Overlay(SecndLay+2, "MainHandTakingOff");
				A_Overlay(SecndLay+1, "GloveTakingOff");
				For(int i=0;i<3;i++)A_OverlayFlags(SecndLay+i, PSPF_ADDWEAPON , false);
				
				A_Overlay(-5, "MainHandTakingOffUnder");
				A_OverlayFlags(-5, PSPF_ADDWEAPON, false);
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(-5, PSPF_MIRROR|PSPF_FLIP, true);
				A_OverlayPivot(-5, .5, .5);
				A_OverlayRotate(-5, -30);
				A_OverlayOffset(-5, 135, 95);
			}
			#### ##### 1{
				For(int i=0;i<3;i++)A_OverlayFlags(SecndLay+i, PSPF_INTERPOLATE, true);
				For(int i=0;i<3;i++)A_OverlayOffset(SecndLay+i, -3, -12, WOF_ADD);
				A_OverlayFlags(-5, PSPF_INTERPOLATE, true);
			}
			#### ##### 1 {
				A_OverlayRotate(OverlayId(), -1.75, WOF_ADD);
				A_OverlayOffset(OverlayId(), 12.5, 3.25, WOF_ADD);
				A_OverlayScale(OverlayId(), 0, -.04, WOF_ADD);
			}
			#### ###### 1 {
				Player.GetPSprite(OverlayId()).Rotation *= .6;
				Player.GetPSprite(OverlayId()).X *= .6;
				Player.GetPSprite(OverlayId()).Y = (Player.GetPSprite(OverlayId()).Y-32)*.6+32;
				Player.GetPSprite(OverlayId()).Scale = (Player.GetPSprite(OverlayId()).Scale-(1,1))*.65+(1,1);
			}
			#### # 1 {
				A_OverlayOffset(OverlayId(), 0, 32, WOF_INTERPOLATE);
				A_OverlayScale(OverlayId(), 1, 1, WOF_INTERPOLATE);
				A_OverlayRotate(OverlayId(), 0, WOF_INTERPOLATE);
			}
			#### # 1 {
				A_OverlayFlags(OverlayId(), PSPF_ADDWEAPON, true);
				A_OverlayOffset(OverlayId(), 0, 0);
				A_OverlayFlags(OverlayId(), PSPF_INTERPOLATE, false);
			}
			Goto SecndHandWait;
		MainHandTakingOff:
			PUN3 F 1 {
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(OverlayId(), PSPF_MIRROR|PSPF_FLIP, true);
				A_OverlayPivot(OverlayId(), .5, .5);
				A_OverlayRotate(OverlayId(), -30);
				A_OverlayOffset(OverlayId(), 135, 95);
			}
			#### # 0 A_StartSound("MRIntW/FistAltSelect", CHAN_AUTO, volume:.7, pitch:CFRandom(.85, .9)*i_timescale);
			#### ## 1 {
				Player.GetPSprite(-5).Rotation = Player.GetPSprite(SecndLay+2).Rotation;
				Player.GetPSprite(-5).X = Player.GetPSprite(SecndLay+2).X;
				Player.GetPSprite(-5).Y = Player.GetPSprite(SecndLay+2).Y;
				Player.GetPSprite(-5).Pivot = Player.GetPSprite(SecndLay+2).Pivot;
			}
			#### ### 1 {
				A_OverlayRotate(OverlayId(), 4, WOF_ADD);
				A_OverlayOffset(OverlayId(), -5.25, -1.3, WOF_ADD);
				
				Player.GetPSprite(-5).Rotation = Player.GetPSprite(SecndLay+2).Rotation;
				Player.GetPSprite(-5).X = Player.GetPSprite(SecndLay+2).X;
				Player.GetPSprite(-5).Y = Player.GetPSprite(SecndLay+2).Y;
			}
			#### # 1{
				A_OverlayRotate(OverlayId(), 5, WOF_ADD);
				A_OverlayOffset(OverlayId(), -9, -1, WOF_ADD);
				
				Player.GetPSprite(-5).Rotation = Player.GetPSprite(SecndLay+2).Rotation;
				Player.GetPSprite(-5).X = Player.GetPSprite(SecndLay+2).X;
				Player.GetPSprite(-5).Y = Player.GetPSprite(SecndLay+2).Y;
			}
			#### #### 1{
				A_OverlayRotate(OverlayId(), 7, WOF_ADD);
				A_OverlayOffset(OverlayId(), -10, 8, WOF_ADD);
				
				Player.GetPSprite(-5).Rotation = Player.GetPSprite(SecndLay+2).Rotation;
				Player.GetPSprite(-5).X = Player.GetPSprite(SecndLay+2).X;
				Player.GetPSprite(-5).Y = Player.GetPSprite(SecndLay+2).Y;
			}
			#### #### 1{
				A_OverlayRotate(OverlayId(), 7, WOF_ADD);
				A_OverlayOffset(OverlayId(), -6, 12, WOF_ADD);
				
				Player.GetPSprite(-5).Rotation = Player.GetPSprite(SecndLay+2).Rotation;
				Player.GetPSprite(-5).X = Player.GetPSprite(SecndLay+2).X;
				Player.GetPSprite(-5).Y = Player.GetPSprite(SecndLay+2).Y;
			}
			#### # 0 A_ClearOverlays(-5, -5);
			Stop;
		MainHandTakingOffUnder:
			PUN3 G 1;
			Wait;
		GloveTakingOff:
			PUN1 F 1{
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(OverlayId(), PSPF_MIRROR|PSPF_FLIP, true);
				Player.GetPSprite(OverlayId()).Translation = invoker.GlovesTrans;

				A_OverlayPivot(OverlayId(), .5, .5);
				A_OverlayRotate(OverlayId(), -5);
				A_OverlayOffset(OverlayId(), -40+10, 70+10);
				A_OverlayScale(OverlayId(), .9, .9);
			}
			#### ## 1;
			#### ### 1{
				A_OverlayRotate(OverlayId(), 4, WOF_ADD);//5
				A_OverlayOffset(OverlayId(), -5.25, .7, WOF_ADD);//-7 1
			}
			#### ## 1{
				A_OverlayRotate(OverlayId(), 8, WOF_ADD);
				A_OverlayOffset(OverlayId(), -10, 9, WOF_ADD);
				A_OverlayScale(OverlayId(), -.05, .05, WOF_ADD);
			}
			#### ## 1{
				A_OverlayRotate(OverlayId(), 10, WOF_ADD);
				A_OverlayOffset(OverlayId(), -8, 18, WOF_ADD);
			}
			#### ### 1{
				A_OverlayScale(OverlayId(), -.1, 0, WOF_ADD);
				A_OverlayRotate(OverlayId(), 7, WOF_ADD);
				A_OverlayOffset(OverlayId(), -4, 12, WOF_ADD);
			}
			#### # 0{if(GetCVar("MRIntW_SecondFist")||(CountInv("PowerStrength") && GetCVar("MRIntW_BersShake")))A_Overlay(MainLay, "MainHandUp");}
			Stop;
		
		TakeOnGloves://Special deselect animation
			PUN3 A 1{
				A_ClearOverlays(MainLay, MainLay);
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(OverlayId(), PSPF_MIRROR|PSPF_FLIP, true);
				A_OverlayPivot(SecndLay, 0, 0);
				A_OverlayOffset(SecndLay, 0, Player.GetPSprite(PSP_WEAPON).Y);
				A_OverlayScale(SecndLay, .98, .98, WOF_INTERPOLATE);
				A_OverlayRotate(SecndLay, 0, WOF_INTERPOLATE);
				A_OverlayFlags(SecndLay, PSPF_ADDWEAPON, false);
				
				A_Overlay(SecndLay+2, "MainHandTakingOn");
				A_OverlayFlags(SecndLay+2, PSPF_ADDWEAPON, false);
				A_Overlay(-5, "MainHandTakingOffUnder");
				if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(-5, PSPF_MIRROR|PSPF_FLIP, true);
				A_OverlayFlags(-5, PSPF_ADDWEAPON|PSPF_INTERPOLATE, false);
				A_OverlayPivot(-5, .5, .5);
				A_OverlayOffset(-5, 0, Player.GetPSprite(PSP_WEAPON).Y+40);
				A_OverlayRotate(-5, 0);
				A_OverlayScale(-5, 1, 1);
			}
			PUN3 ## 1 {
				A_OverlayOffset(SecndLay, -2, 2, WOF_ADD);
				A_OverlayScale(SecndLay, -.04, -.04, WOF_ADD);
			}
			#### ## 1{
				A_OverlayOffset(SecndLay, -1, 6, WOF_ADD);
				A_OverlayRotate(SecndLay, 2, WOF_ADD);
			}
			#### # 0 A_StartSound("MRIntW/FistAltDeselect", CHAN_AUTO, volume:.7, pitch:CFRandom(.8, .85)*i_timescale);
			#### # 1 {
				A_OverlayOffset(SecndLay, 2, 4, WOF_ADD);
				A_OverlayRotate(SecndLay, 1.5, WOF_ADD);
			}
			#### ### 1 {
				A_OverlayOffset(SecndLay, -3.25, -2.5, WOF_ADD);
				A_OverlayRotate(SecndLay, -1, WOF_ADD);
				A_OverlayScale(SecndLay, 0, -.05, WOF_ADD);
				
				A_OverlayOffset(OverlayId(), -1, 3, WOF_ADD);
			}
			#### ## 1 {
				A_OverlayOffset(SecndLay, -5, 3, WOF_ADD);
				A_OverlayRotate(SecndLay, 3, WOF_ADD);
				A_OverlayScale(SecndLay, 0, -.05, WOF_ADD);
				
				A_OverlayOffset(OverlayId(), -1, 3, WOF_ADD);
			}
			#### ### 1 {
				A_OverlayOffset(SecndLay, -7, 4, WOF_ADD);
				A_OverlayRotate(SecndLay, 2, WOF_ADD);
				
				A_OverlayOffset(OverlayId(), -1, 3, WOF_ADD);
			}
			TNT1 A 1;
			Wait;
		MainHandTakingOn:
			#### # 0 {if(GetCVar("MRIntW_RightPunch"))A_OverlayFlags(OverlayId(), PSPF_MIRROR|PSPF_FLIP, true);}
			TNT1 A 0 A_JumpIf(!(GetCVar("MRIntW_SecondFist")||(CountInv("PowerStrength") && GetCVar("MRIntW_BersShake"))), 4);
			PUN3 C 1 {
				A_OverlayPivot(OverlayId(), .5, .5);
				A_OverlayOffset(OverlayId(), 0, Player.GetPSprite(PSP_WEAPON).Y);
				A_OverlayRotate(OverlayId(), 0);
				A_OverlayScale(OverlayId(), 1, 1);
			}
